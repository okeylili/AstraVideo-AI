{
  "version": 2,
  "builds": [
    {
      "src": "frontend/package.json",
      "use": "@vercel/next"
    
    },
    {
      "src": "backend/main.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "backend/main.py"
    },
    {
      "src": "/(.*)",
      "dest": "frontend/$1"
    }
  ],
  "env": {
    "NEXT_PUBLIC_API_URL": "@api-url",
    "REDIS_URL": "@redis-url",
    "CELERY_BROKER_URL": "@celery-broker-url",
    "CELERY_RESULT_BACKEND": "@celery-result-backend"
  },
  "functions": {
    "backend/main.py": {
      "maxDuration": 300
    }
  }
}
